{
  "name": "desktoppet",
  "version": "1.0.0",
  "description": "桌面宠物 - 悬浮在屏幕上的可爱小伙伴",
  "main": "test-require.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [
    "desktop",
    "pet",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^26.6.10",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.desktoppet.app",
    "productName": "DesktopPet",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "settings.html",
      "renderer.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "icon.png",
          "hover/**/*",
          "play/**/*",
          "walk/**/*"
        ]
      }
    ],
    "mac": {
      "icon": "assets/icon.png",
      "category": "public.app-category.entertainment",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
